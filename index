// ── STATE ───────────────────────────────────────────────────────
let day='legs', week='S1';
let doneMain={}, doneWarm=new Set(), doneCore=new Set();
let selWarm=new Set(['inchworm','jumping','mountain','squat_bw']);
let selCore=new Set(['plancha','planchalat','deadbug','russian']);
let timerSec=90, timerRunning=false, timerInt=null;
let modalMode='warm', modalTemp=new Set();
let imgToggle={};

// ── RENDER ──────────────────────────────────────────────────────
function render(){
  const d=DAYS[day];
  document.getElementById('hero-title').textContent=d.title;
  document.getElementById('hero-title').style.color=`var(${d.color})`;
  document.getElementById('hero-meta').textContent=d.meta;
  document.getElementById('hero-tags').innerHTML=d.tags.map(t=>
    `<span class="htag" style="background:var(${d.dim});color:var(${d.color})">${t}</span>`
  ).join('');
  ['legs','push','pull'].forEach(k=>{
    document.getElementById('btn-'+k).className='dt'+(k===day?` on-${k}`:'');
  });
  document.getElementById('prog-fill').style.background=`var(${d.color})`;
  buildContent();
  updateProg();
}

function buildContent(){
  const d=DAYS[day];
  const wList=ALL_WARMUP.filter(e=>selWarm.has(e.id));
  const cList=ALL_CORE.filter(e=>selCore.has(e.id));
  let h='<div class="cards">';

  // WARMUP
  h+=sh('var(--warm)','Calentamiento','warm');
  h+=`<div class="tblock"><div class="tblock-hdr">
    <div class="tblock-title" style="color:var(--warm)">3 SERIES · 25 SEG TRABAJO</div>
    <div class="tblock-sub">10 seg pausa entre ejercicios · Tap para marcar completado · Tap en nombre para ver instrucciones</div>
  </div><div class="tex-list">`;
  wList.forEach(ex=>{
    const done=doneWarm.has(ex.id);
    h+=texItem(ex,done,'warm');
  });
  h+=`</div><div class="tblock-footer">
    <button class="tbtn" style="background:var(--warm)" onclick="startBlock(25)">▶ Timer 25 seg</button>
    <button class="tedit" onclick="openModal('warm')">✏ Editar</button>
  </div></div>`;

  // CORE
  h+=sh('var(--core)','Core','core');
  h+=`<div class="tblock"><div class="tblock-hdr">
    <div class="tblock-title" style="color:var(--core)">4 SERIES · 30 SEG TRABAJO</div>
    <div class="tblock-sub">15 seg pausa entre ejercicios · Tap para marcar completado · Tap en nombre para instrucciones</div>
  </div><div class="tex-list">`;
  cList.forEach(ex=>{
    const done=doneCore.has(ex.id);
    h+=texItem(ex,done,'core');
  });
  h+=`</div><div class="tblock-footer">
    <button class="tbtn" style="background:var(--core)" onclick="startBlock(30)">▶ Timer 30 seg</button>
    <button class="tedit" onclick="openModal('core')">✏ Editar</button>
  </div></div>`;

  // MAIN
  h+=sh(`var(${d.color})`,'Ejercicios principales','');
  d.main.forEach((ex,i)=>{
    const done=!!doneMain[i];
    const s=ex.s[week], r=ex.r[week];
    const show2=!!imgToggle[`${day}-${i}`];
    h+=`<div class="excard${done?' done':''}" id="ec-${i}">
      <div class="excard-media${show2?' show2':''}" onclick="toggleImg('${day}-${i}',this)">
        <img class="img1" src="${ex.img[0]}" loading="lazy" alt="${ex.name}">
        <img class="img2" src="${ex.img[1]}" loading="lazy" alt="${ex.name} paso 2">
        <span class="img-tap-hint">TAP → paso ${show2?'1':'2'}</span>
      </div>
      <div class="excard-body">
        <div class="excard-name">${ex.name}</div>
        <div class="excard-muscle" style="color:var(${d.color})">${ex.muscle}</div>
        <div class="chips">
          <div class="chip"><span class="chip-v" style="color:var(${d.color})">${s}</span><span class="chip-l">SERIES</span></div>
          <div class="chip"><span class="chip-v" style="color:var(${d.color});font-size:${r.length>5?'14px':'20px'}">${r}</span><span class="chip-l">REPS</span></div>
          <div class="chip"><span class="chip-v" style="color:var(${d.color});font-size:14px">${ex.rest}</span><span class="chip-l">DESCANSO</span></div>
        </div>
        <div class="excard-tip">${ex.tip}</div>
        <button class="done-btn${done?' marked':''}" style="${done?`background:var(${d.color})`:''}" onclick="markMain(${i},'${ex.rest}')">
          ${done?'✓ Completado':'→ Marcar hecho'}
        </button>
      </div>
    </div>`;
  });
  h+='</div>';
  document.getElementById('content').innerHTML=h;
}

function texItem(ex,done,type){
  const color=type==='warm'?'var(--warm)':'var(--core)';
  return `<div class="tex-item${done?' done':''}" id="ti-${ex.id}">
    <div class="tex-img-wrap" onclick="toggleTimed('${type}','${ex.id}')">
      <img src="${ex.img[0]}" loading="lazy" alt="${ex.name}" style="width:100%;height:100%;object-fit:cover">
      <div class="done-tick">✓</div>
    </div>
    <div class="tex-body">
      <div class="tex-name" onclick="expandTex('${ex.id}')" style="cursor:pointer">${ex.name}</div>
      <div class="tex-meta" style="color:${color}">${ex.meta}</div>
      <div class="tex-instr" id="ti-instr-${ex.id}">${ex.instr}</div>
      <div class="tex-expand" onclick="expandTex('${ex.id}')" style="color:${color};cursor:pointer" id="ti-exp-${ex.id}">▸ Ver instrucciones</div>
    </div>
  </div>`;
}

function sh(color,label,mode){
  const btn=mode?`<button class="sec-btn" onclick="openModal('${mode}')">✏ Editar</button>`:'';
  return `<div class="sec"><div class="sec-dot" style="background:${color}"></div><span class="sec-lbl">${label}</span><div class="sec-line"></div>${btn}</div>`;
}

function updateProg(){
  const d=DAYS[day];
  const total=d.main.length+selWarm.size+selCore.size;
  const count=Object.values(doneMain).filter(Boolean).length+doneWarm.size+doneCore.size;
  const pct=total?Math.round(count/total*100):0;
  document.getElementById('prog-txt').textContent=`${count} de ${total} completados`;
  document.getElementById('prog-pct').textContent=pct+'%';
  document.getElementById('prog-fill').style.width=pct+'%';
}

// ── INTERACTIONS ────────────────────────────────────────────────
function showDay(d){day=d;doneMain={};doneWarm=new Set();doneCore=new Set();imgToggle={};render();window.scrollTo({top:0,behavior:'smooth'});}
function setWeek(n,el){week='S'+n;document.querySelectorAll('.wc').forEach(c=>c.classList.remove('on'));el.classList.add('on');doneMain={};buildContent();updateProg();}

function markMain(i,rest){
  doneMain[i]=!doneMain[i];
  if(doneMain[i])startBlock(parseRest(rest));
  buildContent();updateProg();
}

function toggleTimed(type,id){
  const s=type==='warm'?doneWarm:doneCore;
  if(s.has(id))s.delete(id);else s.add(id);
  const el=document.getElementById('ti-'+id);
  if(el)el.classList.toggle('done',s.has(id));
  updateProg();
}

function expandTex(id){
  const instr=document.getElementById('ti-instr-'+id);
  const exp=document.getElementById('ti-exp-'+id);
  const item=instr?.closest('.tex-item');
  if(!item)return;
  const open=item.classList.toggle('expanded');
  if(exp)exp.textContent=open?'▾ Ocultar instrucciones':'▸ Ver instrucciones';
}

function toggleImg(key,el){
  imgToggle[key]=!imgToggle[key];
  el.classList.toggle('show2',imgToggle[key]);
  const hint=el.querySelector('.img-tap-hint');
  if(hint)hint.textContent=imgToggle[key]?'TAP → paso 1':'TAP → paso 2';
}

function parseRest(s){const[m,sc]=s.split(':').map(Number);return m*60+(sc||0);}

// ── TIMER ────────────────────────────────────────────────────────
function startBlock(s){timerSec=s;if(timerInt)clearInterval(timerInt);timerRunning=false;updateFab();startTimer();}
function startTimer(){
  if(timerInt)clearInterval(timerInt);
  timerRunning=true;
  document.getElementById('fab').classList.add('running');
  timerInt=setInterval(()=>{
    timerSec--;
    if(timerSec<=0){clearInterval(timerInt);timerInt=null;timerRunning=false;document.getElementById('fab').classList.remove('running');document.getElementById('fab-l').textContent='¡LISTO!';timerSec=0;}
    updateFab();
  },1000);
}
function toggleFab(){
  if(timerRunning){clearInterval(timerInt);timerInt=null;timerRunning=false;document.getElementById('fab').classList.remove('running');}
  else{if(timerSec<=0)timerSec=90;startTimer();}
}
function updateFab(){
  const m=Math.floor(timerSec/60),s=timerSec%60;
  document.getElementById('fab-t').textContent=`${m}:${s.toString().padStart(2,'0')}`;
  if(timerSec>0)document.getElementById('fab-l').textContent='TIMER';
}

// ── MODAL ────────────────────────────────────────────────────────
function openModal(mode){
  modalMode=mode;
  const warm=mode==='warm';
  const list=warm?ALL_WARMUP:ALL_CORE;
  const sel=warm?selWarm:selCore;
  const color=warm?'var(--warm)':'var(--core)';
  modalTemp=new Set(sel);
  document.getElementById('modal-title').textContent=warm?'Calentamiento — seleccionar':'Core — seleccionar';
  document.getElementById('modal-save').style.background=warm?'var(--warm)':'var(--core)';
  document.getElementById('modal-body').innerHTML=list.map(ex=>{
    const s=sel.has(ex.id);
    return `<div class="mitem${s?' sel':''}" id="mi-${ex.id}" style="color:${s?color:'var(--muted)'}" onclick="toggleMItem('${ex.id}','${color}',this)">
      <div class="mitem-img"><img src="${ex.img[0]}" loading="lazy" alt="${ex.name}"></div>
      <div class="mitem-info">
        <div class="mitem-name">${ex.name}</div>
        <div class="mitem-meta">${ex.meta}</div>
        <div class="mitem-instr">${ex.instr}</div>
        <div style="font-size:10px;font-weight:600;color:${color};margin-top:3px;cursor:pointer" onclick="expandMItem('${ex.id}',event)">▸ Instrucciones</div>
      </div>
      <div class="mcheck" style="${s?`border-color:${color};background:${color};color:#0b1120`:''}">${s?'✓':''}</div>
    </div>`;
  }).join('');
  document.getElementById('overlay').classList.add('open');
}
function expandMItem(id,e){
  e.stopPropagation();
  const item=document.getElementById('mi-'+id);
  item.classList.toggle('expanded');
  const btn=e.target;
  btn.textContent=item.classList.contains('expanded')?'▾ Ocultar':'▸ Instrucciones';
}
function toggleMItem(id,color,el){
  if(modalTemp.has(id)){
    if(modalTemp.size<=2)return;
    modalTemp.delete(id);
    el.classList.remove('sel');el.style.color='var(--muted)';
    const c=el.querySelector('.mcheck');c.style.cssText='';c.textContent='';
  } else {
    if(modalTemp.size>=6)return;
    modalTemp.add(id);
    el.classList.add('sel');el.style.color=color;
    const c=el.querySelector('.mcheck');c.style.cssText=`border-color:${color};background:${color};color:#0b1120`;c.textContent='✓';
  }
}
function saveModal(){
  if(modalMode==='warm')selWarm=new Set(modalTemp);else selCore=new Set(modalTemp);
  closeModal();buildContent();updateProg();
}
function closeModal(){document.getElementById('overlay').classList.remove('open');}
function overlayClick(e){if(e.target===document.getElementById('overlay'))closeModal();}

render();
</script>
